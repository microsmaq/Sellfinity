// Sellfinity data model.
// SQLite for local dev; switch provider+url to Postgres for production.
// Conventions: all money is integer cents; "enum" fields are strings with
// allowed values defined in src/lib/types.ts; JSON payloads are serialized
// strings (SQLite) with typed mappers at the read/write boundary.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Pooled connection for the app; direct connection for migrations
  // (connection poolers break Prisma Migrate).
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  name         String
  // FREE | PRO | SCALE
  plan         String    @default("FREE")
  planRenewsAt DateTime?
  // Automatically publish high-confidence profitable Arbitrage Finder matches
  // after a user-initiated scan finishes.
  autoPublishArbitrage Boolean @default(false)
  createdAt    DateTime  @default(now())

  sessions                Session[]
  products                Product[]
  listings                Listing[]
  orders                  Order[]
  syncRuns                SyncRun[]
  syncIssues              SyncIssue[]
  ebayListingSuppressions EbayListingSuppression[]
  ebayMarketMetrics       EbayMarketMetric[]
  hiddenArbitrageItems    HiddenArbitrageItem[]
  mirrorBatches           MirrorBatch[]
  ebayConnection          EbayConnection?
}

// A durable direct-to-eBay publishing run. The browser advances one item at a
// time so progress survives serverless request limits and every outcome is
// retained for the seller's audit history.
model MirrorBatch {
  id             String    @id @default(cuid())
  userId         String
  // URL_BULK | ARBITRAGE
  source         String
  // MANUAL | AUTOMATIC
  trigger        String    @default("MANUAL")
  // PENDING | RUNNING | COMPLETED
  status         String    @default("PENDING")
  totalCount     Int
  succeededCount Int       @default(0)
  failedCount    Int       @default(0)
  // PENDING | SENDING | SENT | FAILED
  emailStatus    String    @default("PENDING")
  emailSentAt    DateTime?
  emailError     String?
  createdAt      DateTime  @default(now())
  startedAt      DateTime?
  completedAt    DateTime?

  user  User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  items MirrorBatchItem[]

  @@index([userId, createdAt])
  @@index([userId, status])
}

model MirrorBatchItem {
  id                String    @id @default(cuid())
  batchId           String
  position          Int
  inputUrl          String
  sourceReferenceId String?
  // PENDING | PROCESSING | SUCCEEDED | FAILED
  status            String    @default("PENDING")
  title             String?
  sourcePriceCents  Int?
  listingPriceCents Int?
  listingId         String?
  ebayListingId     String?
  error             String?
  attempts          Int       @default(0)
  createdAt         DateTime  @default(now())
  startedAt         DateTime?
  completedAt       DateTime?

  batch MirrorBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@unique([batchId, position])
  @@index([batchId, status])
}

// A seller explicitly ended this item through Sellfinity. eBay's ActiveList
// can continue returning ended items for a while, so keep a durable local
// tombstone instead of letting the stale remote row reappear.
model EbayListingSuppression {
  id            String   @id @default(cuid())
  userId        String
  ebayListingId String
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, ebayListingId])
  @@index([userId])
}

// Cached market research for one of the seller's eBay listings. Refreshed on
// demand in batches so opening Listings never fans out hundreds of API calls.
model EbayMarketMetric {
  id                          String   @id @default(cuid())
  userId                      String
  ebayListingId               String
  estimatedSales30d           Int
  competitorCount             Int
  averageCompetitorPriceCents Int
  query                       String
  updatedAt                   DateTime @updatedAt
  createdAt                   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, ebayListingId])
  @@index([userId])
}

model Session {
  id        String   @id // random 256-bit token, also the cookie value
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// The user's eBay seller account connection. Placeholder until real OAuth:
// status SANDBOX means our mock client is in use; CONNECTED is reserved for
// a real token exchange.
model EbayConnection {
  id                   String    @id @default(cuid())
  userId               String    @unique
  // DISCONNECTED | SANDBOX | CONNECTED
  status               String    @default("DISCONNECTED")
  ebayUsername         String?
  // OAuth tokens (encrypt at rest before production).
  accessToken          String?
  accessTokenExpiresAt DateTime?
  refreshToken         String?
  connectedAt          DateTime?
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// A product the user imported from the sourcing feed or mirrored from an
// Amazon URL. Supplier fields snapshot the supplier state at import; sync
// refreshes them.
model Product {
  id                  String   @id @default(cuid())
  userId              String
  sku                 String
  title               String
  description         String
  // JSON string array of image URLs
  imageUrlsJson       String   @default("[]")
  category            String
  supplierName        String
  supplierProductId   String
  supplierUrl         String
  costCents           Int
  supplierStock       Int
  /**
   * Estimated cost for the seller to ship one unit to the buyer.
   */
  shippingCostCents   Int      @default(0)
  suggestedPriceCents Int
  // 0-100 sourcing score at import time
  sourceScore         Int
  createdAt           DateTime @default(now())

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  listings Listing[]

  @@unique([userId, sku])
  @@index([userId])
}

// An eBay listing for a product. Mirrors what we believe the live eBay state
// to be; ebayListingId is set on publish (mock IDs in sandbox mode).
model Listing {
  id            String    @id @default(cuid())
  userId        String
  productId     String
  ebayListingId String?
  title         String
  description   String
  priceCents    Int
  quantity      Int
  imageUrlsJson String    @default("[]")
  // DRAFT | ACTIVE | ENDED
  status        String    @default("DRAFT")
  // UNVERIFIED | MATCH | LIKELY | REVIEW | REJECTED
  sourceMatchVerdict    String    @default("UNVERIFIED")
  sourceMatchConfidence Int?
  sourceMatchReason     String?
  sourceMatchMethod     String?
  sourceMatchCheckedAt  DateTime?
  publishedAt   DateTime?
  endedAt       DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  orders     Order[]
  syncIssues SyncIssue[]

  @@index([userId, status])
  @@index([userId, status, sourceMatchVerdict])
}

// A sale imported from eBay. Fee/cost fields are snapshotted at import so the
// P&L is stable even if fee rates or supplier costs change later.
model Order {
  id                   String   @id @default(cuid())
  userId               String
  listingId            String
  ebayOrderId          String
  quantity             Int
  // per-unit sale price
  salePriceCents       Int
  shippingChargedCents Int      @default(0)
  ebayFeeCents         Int
  shippingCostCents    Int
  cogsCents            Int // total cost of goods for this order
  // PAID | SHIPPED | REFUNDED
  status               String   @default("PAID")
  buyerUsername        String
  saleDate             DateTime
  createdAt            DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([userId, ebayOrderId])
  @@index([userId, saleDate])
}

model SyncRun {
  id              String    @id @default(cuid())
  userId          String
  startedAt       DateTime  @default(now())
  finishedAt      DateTime?
  listingsChecked Int       @default(0)
  issuesFound     Int       @default(0)
  issuesAutoFixed Int       @default(0)

  user   User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  issues SyncIssue[]

  @@index([userId, startedAt])
}

// A researched arbitrage opportunity: a live eBay listing paired with a
// cheaper Amazon source. Global (shared by all users); grows as scans run.
model ArbitrageItem {
  id                String                @id @default(cuid())
  ebayItemId        String                @unique
  ebayTitle         String
  ebayPriceCents    Int
  ebayUrl           String
  imageUrl          String
  category          String
  asin              String
  amazonTitle       String
  amazonPriceCents  Int
  amazonUrl         String
  profitCents       Int
  marginPct         Int
  feeCents          Int
  salesEst          Int
  competitorCount   Int?
  avgCompPriceCents Int?
  matchVerdict      String                @default("UNVERIFIED")
  matchConfidence   Int                   @default(0)
  matchReason       String?
  matchMethod       String                @default("RULES")
  matchCheckedAt    DateTime?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  hiddenBy          HiddenArbitrageItem[]

  @@index([profitCents])
  @@index([category])
  @@index([createdAt])
  @@index([asin])
  @@index([matchVerdict, matchConfidence])
}

// Per-user dismissal of a shared arbitrage research row.
model HiddenArbitrageItem {
  id         String   @id @default(cuid())
  userId     String
  ebayItemId String
  createdAt  DateTime @default(now())

  user User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  item ArbitrageItem @relation(fields: [ebayItemId], references: [ebayItemId], onDelete: Cascade)

  @@unique([userId, ebayItemId])
  @@index([userId])
  @@index([ebayItemId])
}

// Generic JSON cache for expensive external scans (e.g. the daily arbitrage
// scan, which costs paid API credits) — shared across users.
model ScanCache {
  id        String   @id @default(cuid())
  cacheKey  String   @unique
  dataJson  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// A detected mismatch between supplier truth and the live listing.
model SyncIssue {
  id          String    @id @default(cuid())
  syncRunId   String
  userId      String
  listingId   String
  // OUT_OF_STOCK | STOCK_DRIFT | COST_RISE | SUPPLIER_GONE
  type        String
  // JSON string: { field, expected, actual, ... } for display
  detailsJson String
  // OPEN | AUTO_FIXED | FIXED | IGNORED
  resolution  String    @default("OPEN")
  resolvedAt  DateTime?
  createdAt   DateTime  @default(now())

  syncRun SyncRun @relation(fields: [syncRunId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([userId, resolution])
}
